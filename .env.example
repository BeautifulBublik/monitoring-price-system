# Copy to .env and fill in: cp .env.example .env
# The .env file is not committed to git (see .gitignore).

# ---------- Required ----------
# JWT signing key. At least 32 characters — otherwise the application will not start (HS256).
# Generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ---------- Database ----------
POSTGRES_DB=pricemonitor
POSTGRES_USER=pricemonitor
POSTGRES_PASSWORD=pricemonitor
POSTGRES_PORT=5432
APP_PORT=8080

# ---------- Price-check schedule ----------
SCHEDULER_ENABLED=true
# Format — Spring cron (6 fields: sec min hour day month day-of-week).
# Every hour at :00. Every 15 minutes: 0 */15 * * * *
SCHEDULER_CRON=0 0 * * * *

# ON_CHANGE — write only price changes to history (default).
# ALWAYS    — write a point on every check.
HISTORY_STORE_MODE=ON_CHANGE

# ---------- Selenium ----------
SELENIUM_ENABLED=true
SELENIUM_PORT=4444

# ---------- Email ----------
# While MAIL_ENABLED=false, emails are not sent (the channel is simply skipped).
MAIL_ENABLED=false
MAIL_FROM=no-reply@pricemonitor.local
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-address@gmail.com
# For Gmail this is an app password (not your regular account password):
SMTP_PASSWORD=

# ---------- Telegram ----------
# Get the token from @BotFather: /newbot -> name -> username -> the token arrives in reply.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
